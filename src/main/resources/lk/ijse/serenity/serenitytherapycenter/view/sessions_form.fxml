<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="624.0" prefWidth="1115.0" style="-fx-background-color: #e2dec9;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.serenity.serenitytherapycenter.controller.SessionController">
   <children>
      <Text layoutX="23.0" layoutY="52.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Session Management">
         <font>
            <Font name="Algerian" size="33.0" />
         </font>
      </Text>
      <Pane layoutX="34.0" layoutY="72.0" prefHeight="287.0" prefWidth="1067.0" styleClass="dark-card" stylesheets="@stylesheet.css">
         <children>
            <TextField fx:id="s_id_field" layoutX="102.0" layoutY="40.0" prefWidth="180.0" />
            <ComboBox fx:id="s_program_combo_box" layoutX="410.0" layoutY="41.0" onAction="#fillProgramData" prefWidth="180.0" promptText="Select a Program" />
            <TextField fx:id="s_duration_field" layoutX="102.0" layoutY="93.0" prefHeight="30.0" prefWidth="180.0" />
            <TextField fx:id="s_t_contact_field" layoutX="780.0" layoutY="99.0" prefHeight="30.0" prefWidth="238.0" />
            <TextField fx:id="s_t_email_field" layoutX="780.0" layoutY="160.0" prefHeight="30.0" prefWidth="238.0" />
            <TextField fx:id="s_fee_field" layoutX="410.0" layoutY="97.0" prefHeight="30.0" prefWidth="180.0" />
            <ComboBox fx:id="s_day_combo_box" layoutX="102.0" layoutY="141.0" onAction="#initializeTimeCombobox" prefHeight="35.0" prefWidth="180.0" promptText="Pick a Day" />
            <ComboBox fx:id="s_status_combo_box" layoutX="102.0" layoutY="198.0" prefWidth="180.0" promptText="Status" />
            <ComboBox fx:id="s_time_combo_box" layoutX="410.0" layoutY="148.0" prefWidth="180.0" promptText="Pick a Time" />
            <Text fill="WHITE" layoutX="30.0" layoutY="60.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Session ID  :" />
            <Text fill="WHITE" layoutX="330.0" layoutY="65.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Program     :" />
            <Text fill="WHITE" layoutX="30.0" layoutY="115.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Duration    :" />
            <Text fill="WHITE" layoutX="330.0" layoutY="117.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Fee            :" />
            <Text fill="WHITE" layoutX="30.0" layoutY="165.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Day           :" />
            <Text fill="WHITE" layoutX="330.0" layoutY="172.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Time         :" />
            <Text fill="WHITE" layoutX="30.0" layoutY="221.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Status        :" />
            <Text fill="WHITE" layoutX="666.0" layoutY="64.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Therapist Name  :" />
            <ComboBox fx:id="s_t_combo_box" layoutX="780.0" layoutY="37.0" onAction="#fillTherapistData" prefHeight="36.0" prefWidth="238.0" />
            <Text fill="#fffefe" layoutX="666.0" layoutY="118.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Contact               :" />
            <Text fill="WHITE" layoutX="666.0" layoutY="183.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Email                   :" />
            <ButtonBar layoutX="753.0" layoutY="221.0" prefHeight="40.0" prefWidth="200.0">
              <buttons>
                  <Button fx:id="s_btn_save" mnemonicParsing="false" onAction="#handelSaveSession" styleClass="save-btn" text="Save" />
                  <Button fx:id="s_btn_update" mnemonicParsing="false" onAction="#handelUpdateSession" styleClass="update-btn" text="Update" />
                <Button mnemonicParsing="false" onAction="#clearFields" styleClass="reset-btn" text="Reset" />
              </buttons>
            </ButtonBar>
         </children>
      </Pane>
      <TableView fx:id="session_table" layoutX="28.0" layoutY="464.0" prefHeight="142.0" prefWidth="1064.0" stylesheets="@stylesheet.css">
        <columns>
          <TableColumn fx:id="col_id" prefWidth="145.0" text="Session ID" />
          <TableColumn fx:id="col_program" prefWidth="199.0" text="Program" />
            <TableColumn fx:id="col_therapist" prefWidth="133.0" text="Therapist" />
            <TableColumn fx:id="col_day" prefWidth="205.0" text="Day" />
            <TableColumn fx:id="col_time" prefWidth="215.0" text="Time" />
            <TableColumn fx:id="col_status" prefWidth="159.0" text="Status" />
        </columns>
      </TableView>
      <Pane layoutX="170.0" layoutY="363.0" prefHeight="88.0" prefWidth="795.0" styleClass="dark-card" stylesheets="@stylesheet.css">
         <children>
            <ToolBar layoutX="67.0" layoutY="21.0" prefHeight="40.0" prefWidth="286.0" styleClass="search-toolbar">
              <items>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Search By" />
                  <Line endX="-100.0" endY="19.0" startX="-100.0" stroke="#ae6b6b" />
                  <RadioButton fx:id="s_id_radio" mnemonicParsing="false" onAction="#uncheckOthers" text="ID" />
                  <Line endX="-100.0" endY="19.0" startX="-100.0" stroke="#fcfcfc" />
                  <RadioButton fx:id="s_t_radio" mnemonicParsing="false" onAction="#uncheckOthers" text="Therapist" />
                  <Line endX="-100.0" endY="19.0" startX="-100.0" stroke="#fcfcfc" />
                  <RadioButton fx:id="s_p_radio" mnemonicParsing="false" onAction="#uncheckOthers" text="Program" />
                  <Line endX="-100.0" endY="19.0" startX="-100.0" stroke="#fcfcfc" />
              </items>
            </ToolBar>
            <TextField fx:id="s_search_field" layoutX="404.0" layoutY="23.0" prefHeight="31.0" prefWidth="286.0" styleClass="search-field" />
            <Button layoutX="700.0" layoutY="25.0" mnemonicParsing="false" onAction="#handelSearchSession" styleClass="search-btn" text="Search" />
         </children>
      </Pane>
   </children>
</AnchorPane>
