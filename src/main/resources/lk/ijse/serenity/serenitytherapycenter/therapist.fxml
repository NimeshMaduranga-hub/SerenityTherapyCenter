<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="624.0" prefWidth="1115.0" style="-fx-background-color: #e2dec9;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.serenity.serenitytherapycenter.controller.TherapistController">
   <children>
      <Text fill="#575b51" layoutX="23.0" layoutY="52.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Therapist Management">
         <font>
            <Font name="Algerian" size="33.0" />
         </font>
      </Text>
      <Pane layoutX="75.0" layoutY="69.0" prefHeight="353.0" prefWidth="961.0" styleClass="card" stylesheets="@stylesheet.css">
         <children>
            <TextField fx:id="t_id_field" layoutX="200.0" layoutY="50.0" prefHeight="30.0" prefWidth="332.0" styleClass="text-field" />
            <TextField fx:id="t_name_field" layoutX="200.0" layoutY="100.0" prefHeight="30.0" prefWidth="332.0" />
            <TextField fx:id="t_contact_field" layoutX="200.0" layoutY="150.0" prefHeight="30.0" prefWidth="332.0" />
            <TextField fx:id="t_email_field" layoutX="200.0" layoutY="200.0" prefHeight="30.0" prefWidth="332.0" />
            <Text layoutX="91.0" layoutY="69.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Therapist ID          : " />
            <Text layoutX="91.0" layoutY="120.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Therapist Name   :" />
            <Text layoutX="91.0" layoutY="170.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Contact number   :" />
            <Text layoutX="91.0" layoutY="220.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Email Address       :" />
            <ButtonBar layoutX="176.0" layoutY="272.0" prefHeight="40.0" prefWidth="200.0">
              <buttons>
                <Button fx:id="t_btn_save" mnemonicParsing="false" onAction="#handelSaveTherapist" styleClass="save-btn" text="Save" />
                  <Button fx:id="t_btn_update" mnemonicParsing="false" onAction="#handelUpdateTherapist" styleClass="update-btn" text="Update" />
                  <Button fx:id="t_btn_delete" mnemonicParsing="false" onAction="#handelDeleteTherapist" styleClass="delete-btn" text="Delete" />
                  <Button mnemonicParsing="false" onAction="#clearFields" styleClass="reset-btn" text="Reset" />
              </buttons>
            </ButtonBar>
            <TextField fx:id="t_search_field" layoutX="624.0" layoutY="32.0" prefHeight="31.0" prefWidth="224.0" styleClass="search-field">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
            </TextField>
            <Button layoutX="853.0" layoutY="32.0" mnemonicParsing="false" onAction="#handelSearchTherapist" styleClass="search-btn" text="Search">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
            </Button>
            <Label fx:id="p_search_text" layoutX="631.0" layoutY="13.0" text="Search Therapist by ID or Name">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
            </Label>
         </children>
      </Pane>
      <TableView fx:id="therapist_table" layoutX="75.0" layoutY="426.0" prefHeight="182.0" prefWidth="961.0" stylesheets="@stylesheet.css">
        <columns>
          <TableColumn fx:id="col_t_id" prefWidth="170.0" text="ID" />
          <TableColumn fx:id="col_t_name" prefWidth="278.0" text="Name" />
            <TableColumn fx:id="col_t_contact" prefWidth="197.0" text="Contact" />
            <TableColumn fx:id="col_t_email_address" prefWidth="311.0" text="Email Address" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
